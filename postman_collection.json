                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"CANDIDATE\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:3000/api/auth/signup",
