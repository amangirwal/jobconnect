        {
            "name": "Jobs",
            "item": [
                {
                    "name": "Get All Jobs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "http://localhost:3000/api/jobs",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "3000",
                            "path": [
                                "api",
                                "jobs"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Job",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Backend Developer\",\n    \"company\": \"Tech Corp\",\n    \"description\": \"We are looking for a Node.js developer...\",\n    \"location\": \"Remote\",\n    \"salary\": \"$120k\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:3000/api/jobs",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "3000",
                            "path": [
                                "api",
                                "jobs"
                            ]
